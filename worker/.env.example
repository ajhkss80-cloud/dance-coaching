# ====================================================
# Dance Coaching Platform - Worker Configuration
# ====================================================
# Copy this file to .env and fill in the values.

# --- Backend selection ---
# Options: cloud, local, comfyui
GENERATION_BACKEND=cloud

# --- Cloud provider selection ---
# Used when GENERATION_BACKEND=cloud
# Options: wavespeed, kling, falai
CLOUD_PROVIDER=wavespeed

# Cloud model variant (used by WaveSpeed):
#   steady-dancer, wan-animate
# For fal.ai, use FALAI_MODEL instead
CLOUD_MODEL=steady-dancer

# --- WaveSpeed AI ---
# Required when CLOUD_PROVIDER=wavespeed
WAVESPEED_API_KEY=
# Resolution: 480p, 720p
WAVESPEED_RESOLUTION=720p

# --- fal.ai ---
# Required when CLOUD_PROVIDER=falai
FALAI_API_KEY=
# Model options: kling-v3-standard-mc, kling-v3-pro-mc, wan-animate
FALAI_MODEL=kling-v3-standard-mc

# --- Kling (EvoLink) ---
# Required when CLOUD_PROVIDER=kling
KLING_API_KEY=
# Quality: 720p ($0.113/sec), 1080p ($0.151/sec)
KLING_QUALITY=720p
# Character orientation: video, image
KLING_CHARACTER_ORIENTATION=video

# --- MimicMotion (local GPU) ---
# Used when GENERATION_BACKEND=local
MIMICMOTION_MODEL_DIR=./models/mimicmotion
MIMICMOTION_REPO_DIR=./vendor/MimicMotion

# --- ComfyUI ---
# Used when GENERATION_BACKEND=comfyui
COMFYUI_URL=http://localhost:8188
COMFYUI_WORKFLOW_TEMPLATE=
COMFYUI_MODEL_NODE_CLASS=SteadyDancerBasic
COMFYUI_INFERENCE_STEPS=50
COMFYUI_SEED=42

# --- Storage ---
STORAGE_DIR=./storage

# --- Segmentation ---
SEGMENT_MAX_LENGTH_SEC=10
MAX_VIDEO_DURATION_SEC=180

# --- Redis / BullMQ ---
REDIS_URL=redis://localhost:6379
WORKER_CONCURRENCY=1

# --- RIFE Interpolation ---
RIFE_MODEL_DIR=./models/rife
RIFE_INTERPOLATION_FRAMES=2
