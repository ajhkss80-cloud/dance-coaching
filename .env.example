# ==================================
# Dance Coaching Platform Configuration
# ==================================

# Server
SERVER_PORT=3000
REDIS_URL=redis://localhost:6379

# Generation Backend: 'cloud' or 'local'
GENERATION_BACKEND=cloud

# Cloud Backend (Kling API)
KLING_API_KEY=
KLING_API_BASE_URL=https://api.klingai.com/v1

# Local GPU Backend (MimicMotion)
MIMICMOTION_MODEL_DIR=./models/mimicmotion
MIMICMOTION_REPO_DIR=./vendor/MimicMotion

# Pipeline Settings
MAX_VIDEO_DURATION_SEC=180
SEGMENT_MAX_LENGTH_SEC=10
RIFE_MODEL_DIR=./models/rife
RIFE_INTERPOLATION_FRAMES=2

# Storage
STORAGE_DIR=./storage

# Worker
WORKER_CONCURRENCY=1
