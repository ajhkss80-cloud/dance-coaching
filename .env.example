# ==================================
# Dance Coaching Platform Configuration
# ==================================

# Server
SERVER_PORT=3000
REDIS_URL=redis://localhost:6379

# Generation Backend: 'cloud', 'local', or 'comfyui'
GENERATION_BACKEND=cloud

# Cloud Backend (Kling API)
KLING_API_KEY=
KLING_API_BASE_URL=https://api.klingai.com/v1

# Local GPU Backend (MimicMotion - legacy)
MIMICMOTION_MODEL_DIR=./models/mimicmotion
MIMICMOTION_REPO_DIR=./vendor/MimicMotion

# ComfyUI Backend (recommended for local GPU)
# Supports: SteadyDancer, SCAIL, Wan2.2 Animate, etc.
COMFYUI_URL=http://localhost:8188
COMFYUI_WORKFLOW_TEMPLATE=
COMFYUI_MODEL_NODE_CLASS=SteadyDancerBasic
COMFYUI_INFERENCE_STEPS=50
COMFYUI_SEED=42

# Pipeline Settings
MAX_VIDEO_DURATION_SEC=180
SEGMENT_MAX_LENGTH_SEC=10
RIFE_MODEL_DIR=./models/rife
RIFE_INTERPOLATION_FRAMES=2

# Storage
STORAGE_DIR=./storage

# Worker
WORKER_CONCURRENCY=1
